<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lewchu">
    <!--登陆接口-->
    <select id="login" parameterType="com.lewchu.model.User" resultType="Integer">
        select count(*) from user where name=#{name} and password=#{password}
    </select>
    
    <!--添加用户接口-->
    <insert id="addUser" parameterType="com.lewchu.model.User">
        insert into user(name,password,age,sex,permission,isDelete) values(#{name},#{password},#{age},#{sex},#{permission},#{isDelete})
    </insert>
    
    <select id="getUserInfo" parameterType="Integer" resultType="com.lewchu.model.User">
        select * from user where id=#{id}
    </select>
    
    <!--获取用户列表接口-->
    <select id="getUserList" parameterType="com.lewchu.model.User" resultType="com.lewchu.model.User">
        select * from user where sex=#{sex}
    </select>
    
    <!--更新/删除用户信息-->
    <update id="updateUser" parameterType="com.lewchu.model.User">
        update user
            <trim prefix="SET" suffixOverrides=",">
                <if test="name != null and name != ''">
                    name=#{name},
                </if>
                <if test="password != null and password != ''">
                    password=#{password},
                </if>
                <if test="age != null">
                    age=#{age},
                </if>
                <if test="sex != null and sex != ''">
                    sex=#{sex},
                </if>
                <if test="permission != null">
                    permission=#{permission},
                </if>
                <if test="isDelete != null">
                    isDelete=#{isDelete},
                </if>
            </trim>
        where id=#{id}
    </update>
</mapper>
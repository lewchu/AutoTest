<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lewchu">
    <select id="loginCase" parameterType="Integer" resultType="com.lewchu.model.LoginCase">
        select * from loginCase where id= #{id};
    </select>
    <select id="addUserCase" parameterType="Integer" resultType="com.lewchu.model.AddUserCase">
        select * from addUserCase where id= #{id};
    </select>
    
    <select id="getUserInfoCase" parameterType="Integer" resultType="com.lewchu.model.GetUserInfoCase">
        select * from getUserInfoCase where id=#{id};
    </select>
    
    <select id="getUserInfoListCase" parameterType="String" resultType="com.lewchu.model.GetUserListCase">
        select * from getUserListCase where sex=#{sex};
    </select>
    
    <select id="updateUserInfoCase" parameterType="Integer" resultType="com.lewchu.model.UpdateUserInfoCase">
        select * from updateUserInfoCase where id= #{id};
    </select>
    
    <!--获取用户信息-->
    <select id="getUserInfo" parameterType="com.lewchu.model.GetUserInfoCase" resultType="com.lewchu.model.User">
        select * from user where id=#{userId};
    </select>
    <!--获取用户列表-->
    <select id="getUserList" parameterType="String" resultType="com.lewchu.model.User">
        select * from user where sex=#{sex}
    </select>
    <!--获取更新之后的数据-->
    <select id="getUpdateUserInfo" parameterType="Integer" resultType="com.lewchu.model.User">
            select * from user where id = #{userId}
    </select>
    <!--添加用户信息-->
    <select id="addUser" parameterType="com.lewchu.model.AddUserCase" resultType="com.lewchu.model.User">
        select * from user where
        name = #{name} and password = #{password}
        and age = #{age} and sex = #{sex}
        and permission = #{permission} and isDelete = #{isDelete}
    </select>        
</mapper>